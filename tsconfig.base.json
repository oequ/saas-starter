{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@oequ/ports": [
        "./libs/ports/src/index.ts"
      ],
      "@oequ/shell": [
        "./libs/shell/src/index.ts"
      ],
      "@oequ/adapters-mock": [
        "./libs/adapters-mock/src/index.ts"
      ],
      "@oequ/ui": [
        "./libs/ui/src/index.ts"
      ],
      "@oequ/features-org": [
        "./libs/features-org/src/index.ts"
      ],
      "@oequ/features-auth": [
        "./libs/features-auth/src/index.ts"
      ],
      "@spartan-ng/helm/breadcrumb": [
        "./libs/ui/breadcrumb/src/index.ts"
      ],
      "@spartan-ng/helm/button": [
        "./libs/ui/button/src/index.ts"
      ],
      "@spartan-ng/helm/card": [
        "./libs/ui/card/src/index.ts"
      ],
      "@spartan-ng/helm/input": [
        "./libs/ui/input/src/index.ts"
      ],
      "@spartan-ng/helm/select": [
        "./libs/ui/select/select/src/index.ts"
      ],
      "@spartan-ng/helm/separator": [
        "./libs/ui/separator/src/index.ts"
      ],
      "@spartan-ng/helm/sidebar": [
        "./libs/ui/sidebar/src/index.ts"
      ],
      "@spartan-ng/helm/tabs": [
        "./libs/ui/tabs/src/index.ts"
      ],
      "@spartan-ng/helm/utils": [
        "./libs/ui/utils/src/index.ts"
      ],
      "@spartan-ng/helm/icon": [
        "./libs/ui/icon/src/index.ts"
      ],
      "@spartan-ng/helm/sheet": [
        "./libs/ui/sheet/src/index.ts"
      ],
      "@spartan-ng/helm/skeleton": [
        "./libs/ui/skeleton/src/index.ts"
      ],
      "@spartan-ng/helm/tooltip": [
        "./libs/ui/tooltip/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
